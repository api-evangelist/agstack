{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agstack.org/schemas/AppliedAmmountField.json",
  "title": "AppliedAmmountField",
  "type": "object",
  "properties": {
    "unit": {
      "type": "string"
    },
    "numericValue": {
      "type": "string",
      "format": "decimal",
      "pattern": "^-?\\d{0,15}(?:\\.\\d{0,2})?$"
    }
  },
  "required": [
    "numericValue",
    "unit"
  ]
}