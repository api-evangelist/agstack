{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agstack.org/schemas/Body_token_auth_token_post.json",
  "title": "Body_token_auth_token_post",
  "properties": {
    "grant_type": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "password"
        },
        {
          "type": "null"
        }
      ],
      "title": "Grant Type"
    },
    "username": {
      "type": "string",
      "title": "Username"
    },
    "password": {
      "type": "string",
      "title": "Password"
    },
    "scope": {
      "type": "string",
      "title": "Scope",
      "default": ""
    },
    "client_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Client Id"
    },
    "client_secret": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Client Secret"
    }
  },
  "type": "object",
  "required": [
    "username",
    "password"
  ]
}