{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agstack.org/schemas/LocationSerializerField.json",
  "title": "LocationSerializerField",
  "type": "object",
  "properties": {
    "lat": {
      "type": "string",
      "format": "decimal",
      "pattern": "^-?\\d{0,3}(?:\\.\\d{0,14})?$"
    },
    "long": {
      "type": "string",
      "format": "decimal",
      "pattern": "^-?\\d{0,3}(?:\\.\\d{0,14})?$"
    }
  },
  "required": [
    "lat",
    "long"
  ]
}